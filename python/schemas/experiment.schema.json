{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/experiment.schema.json",
  "title": "ExperimentConfig",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "name": { "type": "string" },
    "seed": { "type": "integer" },
    "max_turns": { "type": "integer", "minimum": 1 },
    "backend": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "kind": { "type": "string", "enum": ["dummy", "openai", "gemini"] },
        "seed": { "type": "integer" },
        "model": { "type": "string" },
        "api_key": { "type": "string" },
        "base_url": { "type": "string" }
      },
      "required": ["kind"]
    },
    "tools": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "kind": { "type": "string", "enum": ["rag", "web", "mcp"] },
          "corpus": { "type": "array", "items": { "type": "string" } },
          "endpoint": { "type": "string" }
        },
        "required": ["kind"]
      }
    },
    "strategy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "enum": ["vanilla"] },
        "temperature": { "type": "number", "minimum": 0, "maximum": 2 }
      },
      "required": ["name"]
    },
    "orchestrator": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "pipe": { "type": "string" }
      }
    },
    "logging": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "dir": { "type": "string" }
      }
    }
  },
  "required": ["name", "backend", "strategy"]
}

